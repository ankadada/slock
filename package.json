{
  "name": "slock",
  "version": "0.1.0",
  "private": true,
  "description": "Team communication platform with AI agents",
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter web dev\"",
    "build": "pnpm --filter shared build && pnpm --filter web build && pnpm --filter server build",
    "start": "pnpm --filter server start",
    "db:push": "pnpm --filter server db:push",
    "db:studio": "pnpm --filter server db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}